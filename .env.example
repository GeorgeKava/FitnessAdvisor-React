# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"
AZURE_OPENAI_API_VERSION="2024-05-01-preview"
AZURE_OPENAI_API_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_MODEL="gpt-4o"
AZURE_OPENAI_DEPLOYMENT_ID="gpt-4o"

# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT="https://your-search-service.search.windows.net"
AZURE_SEARCH_ADMIN_KEY="your-azure-search-admin-key"
AZURE_SEARCH_INDEX_NAME="fitness-index"
AZURE_SEARCH_USER_DATA_INDEX="user_data"

# Azure OpenAI Real-Time API (Voice Chat)
WEBRTC_URL="https://your-region.realtimeapi-preview.ai.azure.com/v1/realtimertc"
SESSIONS_URL="https://your-resource.openai.azure.com/openai/realtimeapi/sessions?api-version=2025-04-01-preview"
API_KEY="your-realtime-api-key"
DEPLOYMENT="gpt-4o-realtime-preview"
VOICE="verse"
AZURE_VOICE_ID="en-US-JennyNeural"
AZURE_TRANSCRIPTION_MODEL="whisper-1"
PROJECT_ENDPOINT="https://your-project-resource.services.ai.azure.com/api/projects/your-project"

# MCP Configuration
DISABLE_MCP="true"
MCP_CONNECTION_TIMEOUT="60.0"
MCP_TOOL_TIMEOUT="30.0"
MCP_RESOURCE_TIMEOUT="30.0"

# Agentic RAG Configuration
ENABLE_AGENTIC_RAG="true"
AGENTIC_RAG_MAX_ITERATIONS="3"
AGENTIC_RAG_REFLECTION_MODE="true"

# AI Model Configuration
AI_TEMPERATURE="0.7"
AI_FAST_TEMPERATURE="0.5"
AI_FORMATTING_TEMPERATURE="0.3"
AI_MAX_TOKENS="2500"
AI_FAST_MAX_TOKENS="800"
AI_FORMATTING_MAX_TOKENS="3000"
AGENTIC_RAG_MAX_TOKENS="800"

# Flask Configuration
FLASK_DEBUG="true"
FLASK_HOST="127.0.0.1"
FLASK_PORT="5000"
